<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit</title>
  </head>
  <body>
    <h1>Edit book note</h1>
    <form action="/edit" method="POST">
      <input type="hidden" name="id" value="<%= book.id %>" />

      <div>
        <label for="title">Title:</label>
        <input
          type="text"
          id="title"
          name="updatedTitle"
          value="<%= book.title %>"
        />
      </div>
      <br />

      <div>
        <label for="rating">Rating:</label>
        <input
          type="text"
          id="rating"
          name="updatedRating"
          value="<%= book.rating %>"
        />
      </div>
      <br />

      <div>
        <label for="isbn">ISBN:</label>
        <input
          type="text"
          id="isbn"
          name="updated_isbn"
          value="<%= book.isbn %>"
        />
      </div>
      <br />

      <div>
        <label for="updatedDescription">Description:</label><br />
        <textarea cols="30" name="description" id="updatedDescription" rows="5">
<%= book.description %></textarea
        >
      </div>
      <br />

      <button type="submit">Submit update</button>
    </form>
  </body>
</html>

