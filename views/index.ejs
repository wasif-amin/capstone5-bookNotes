<!DOCTYPE html>
<html lang="en">
  <head>
    <link rel="stylesheet" href="/styles.css" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Book Notes</title>
  </head>
  <body>
    <h1>Book Notes</h1>
    <% if (isAdmin) { %>
    <a href="/compose" class="btn-add">Add New Book Note</a>
    <% } %>
    <div class="book-container">
      <% entries.forEach(book => { %>
      <!-- <div class="book-card">
        <h2 class="book-title"><%= book.title %></h2>

        <p>
          <strong>rating:</strong> <%= book.rating %>
          <span class="spacer"></span>
          <strong>description:</strong> <%= book.description %>
        </p>
      </div> -->
      <div class="book-item">
        <h3><%= book.title %></h3>
        <p><strong>Rating:</strong> <%= book.rating %></p>
        <p><strong>Description:</strong> <%= book.description %></p>
        <img
          src="https://covers.openlibrary.org/b/isbn/<%= book.isbn %>-M.jpg"
          alt="Book Cover"
        />
        <!-- <form
          action="/edit/<%= book.id %>"
          method="GET"
          style="display: inline-block; margin-top: 10px"
        >
          <a href="edit.ejs?id=<%= book.id %>">
            <button style="background-color: skyblue; color: white" type="submit">
              edit note
            </button>
          </a>
        </form>
        <form action="/delete" method="POST" style="margin-top: 10px">
          <input type="hidden" name="deleteItemId" value="<%= book.id %>" />
          <button style="background-color: orange; color: white" type="submit">
            delete note
          </button>
        </form> -->
        <% if (isAdmin) { %>
        <div class="admin-controls">
          <a href="/edit/<%= book.id %>" class="btn-edit"
            ><button>edit</button></a
          >

          <form action="/delete" method="POST" style="display: inline">
            <input type="hidden" name="deleteItemId" value="<%= book.id %>" />
            <button type="submit" class="btn-delete">Delete</button>
          </form>
        </div>
        <% } %>
      </div>

      <% }); %>
    </div>
  </body>
</html>
